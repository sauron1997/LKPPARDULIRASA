{
  "name": "lkp-parduli-rasa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n web,api \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm --workspace @lkp-parduli-rasa/web run dev",
    "dev:api": "npm --workspace @lkp-parduli-rasa/api run dev",
    "start": "npm --workspace @lkp-parduli-rasa/api run start",
    "build": "npm --workspace @lkp-parduli-rasa/web run build",
    "lint": "eslint .",
    "preview": "npm --workspace @lkp-parduli-rasa/web run preview",
    "smoke:api": "node scripts/dev-smoke.mjs api",
    "smoke:web": "node scripts/dev-smoke.mjs web",
    "smoke:dev": "node scripts/dev-smoke.mjs full",
    "graphify:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\graphify.ps1 doctor",
    "graphify:update": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\graphify.ps1 update .",
    "graphify:query": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\graphify.ps1 query",
    "graphify:path": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\graphify.ps1 path",
    "graphify:explain": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\graphify.ps1 explain",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "npm --workspace @lkp-parduli-rasa/api run db:seed",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "npx @better-auth/cli@latest generate",
    "auth:secret": "npx @better-auth/cli@latest secret"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0"
  }
}
