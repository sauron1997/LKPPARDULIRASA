{
  "name": "lkp-parduli-rasa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,server \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite --configLoader native",
    "dev:server": "node --watch server/src/index.js",
    "start": "node server/src/index.js",
    "build": "vite build --configLoader native",
    "lint": "eslint .",
    "preview": "vite preview --configLoader native",
    "graphify:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\graphify.ps1 doctor",
    "graphify:update": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\graphify.ps1 update .",
    "graphify:query": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\graphify.ps1 query",
    "graphify:path": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\graphify.ps1 path",
    "graphify:explain": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\graphify.ps1 explain",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node server/src/db/seed.js",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "npx @better-auth/cli@latest generate",
    "auth:secret": "npx @better-auth/cli@latest secret"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.10",
    "@tanstack/react-query": "^5.100.10",
    "@tiptap/extension-color": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "better-auth": "^1.6.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "lucide-react": "^0.577.0",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.1"
  }
}
