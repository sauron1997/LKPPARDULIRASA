# ============================================================
# Environment Configuration — LKP Parduli Rasa API
# Salin file ini ke .env dan sesuaikan nilainya
# JANGAN commit file .env ke git!
# ============================================================

# -- Aplikasi --
APP_NAME=LKP Parduli Rasa API
HOST=localhost
PORT=3001

# -- CORS & Origin (gunakan https:// di production) --
CLIENT_ORIGIN=https://domain-anda.com
CORS_ORIGINS=https://domain-anda.com

# -- API & Auth Paths --
API_BASE_PATH=/api
AUTH_BASE_PATH=/api/auth

# -- Better Auth (WAJIB diganti sebelum production!) --
# Generate secret kuat: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_URL=https://domain-anda.com/api/auth
BETTER_AUTH_SECRET=GANTI-DENGAN-SECRET-ACAK-MINIMAL-32-KARAKTER

# -- Database PostgreSQL --
DATABASE_URL=postgres://user:password@localhost:5432/lkp_parduli_rasa
# SSL mode untuk koneksi database:
#   require     = SSL wajib + verifikasi sertifikat (production)
#   no-verify   = SSL tanpa verifikasi (staging/dev dengan self-signed cert)
#   disable     = Tanpa SSL (development lokal saja)
DATABASE_SSL_MODE=require

# -- Upload Files --
# Gunakan path absolut di production
UPLOADS_DIR=/var/www/lkp-parduli-rasa/uploads

# -- Midtrans Payment Gateway --
# Sandbox (testing):
# MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
# MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
# MIDTRANS_IS_PRODUCTION=false
# Production:
# MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxx
# MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxx
# MIDTRANS_IS_PRODUCTION=true
# WEBHOOK_BASE_URL=https://domain-anda.com/api
