NODE_ENV=production
HOST=127.0.0.1
PORT=3001

CLIENT_ORIGIN=https://domain-anda
CORS_ORIGINS=https://domain-anda
API_BASE_PATH=/api
AUTH_BASE_PATH=/api/auth

BETTER_AUTH_URL=https://domain-anda/api/auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

DATABASE_URL=postgres://username:password@127.0.0.1:5432/lkp_parduli_rasa
DATABASE_SSL_MODE=disable

UPLOADS_DIR=/var/lib/lkp-parduli-rasa/uploads

# Keep empty for same-origin production behind Nginx.
VITE_API_BASE_URL=

# === Midtrans Payment Gateway ===
# Wajib diisi untuk mengaktifkan pembayaran. Jika kosong, sistem akan berjalan di Mock Mode (tidak untuk produksi!).
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=true
# Callback URL untuk notifikasi Midtrans (webhook). Pastikan URL ini dapat diakses publik.
WEBHOOK_BASE_URL=https://domain-anda/api
